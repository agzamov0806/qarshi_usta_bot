# Telegram: @BotFather dan olingan token
BOT_TOKEN=123456789:ABCdef...

# Admin Telegram ID (raqam). @userinfobot
ADMIN_CHAT_ID=123456789

# PostgreSQL (docker compose up -d — localhost:5432)
DATABASE_URL=postgresql+asyncpg://usta:usta_dev_change@localhost:5432/usta_bot

# Railway: Postgres plugin `DATABASE_URL` ni odatda `postgresql://...` qilib beradi —
# kod uni avtomatik `postgresql+asyncpg://...` ga aylantiradi. Qo'lda o'zgartirish shart emas.

# Eski SQLite dan ko'chirish (ixtiyoriy):
# SQLITE_SOURCE=data/app.db python scripts/migrate_sqlite_to_postgres.py

# SQLite qayta ishlatish (docker siz):
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db
