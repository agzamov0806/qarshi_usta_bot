# Telegram: @BotFather dan olingan token
BOT_TOKEN=123456789:ABCdef...

# Admin Telegram ID (raqam). @userinfobot
ADMIN_CHAT_ID=123456789

# Ixtiyoriy. Berilmasa — loyiha ichidagi standart SQLite (./data/app.db) ishlatiladi.
# Lokal Docker Postgres:
# DATABASE_URL=postgresql+asyncpg://usta:usta_dev_change@localhost:5432/usta_bot

# Railway: Postgres qo‘shing — `DATABASE_URL` odatda avtomatik beriladi;
# `postgresql://...` ham bo‘lsa, kod `postgresql+asyncpg://...` ga aylantiradi.

# Eski SQLite dan Postgres ga ko'chirish:
# SQLITE_SOURCE=data/app.db python scripts/migrate_sqlite_to_postgres.py
